# Copy this file to .env, then run `npm run dev`. .env is gitignored.
# No quotes around values. Lines starting with # are ignored.

# ── Drive the demo: the Serve and Author screens call a model ──────────────────
# Uncomment and fill in EXACTLY ONE of the two options below. (With neither, the app
# still runs and every screen works — Serve just hands off instead of answering.)

# Option A — Claude (Anthropic). Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Option B — an Anthropic-compatible endpoint (e.g. Z.ai GLM). Leave Option A out.
# TIMESHIFT_AUTH_TOKEN=your-provider-key      # sent as a Bearer token
# TIMESHIFT_BASE_URL=https://api.z.ai/api/anthropic
# TIMESHIFT_MODEL=glm-4.7
# TIMESHIFT_NO_THINK=1                         # compat endpoints often reject Anthropic's thinking param

# ── Parked: the multi-tenant SaaS stack (slice 2b — NOT needed to drive the demo) ─
# Managed by Doppler (dev + prd configs). See setup-doppler.
# DATABASE_URL=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ADMIN_EMAIL=
# SESSION_SECRET=
# NODE_ENV=
