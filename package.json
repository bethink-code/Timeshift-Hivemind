{
  "name": "@timeshift/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TimeShift resolver core — pure, dependency-free composition engine (spec v0.2)",
  "scripts": {
    "dev": "node scripts/free-port.mjs && tsx --env-file-if-exists=.env server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:shared": "tsc -p tsconfig.shared.json",
    "build:cli": "esbuild tools/materialize-cli.ts --bundle --platform=node --format=esm --outfile=dist/materialize-cli.mjs",
    "build:scan": "esbuild tools/scan-cli.ts --bundle --platform=node --format=esm --outfile=dist/scan.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
